# 本机 MySQL 配置示例（连接 localhost，不连 192.168.1.160）
# 使用步骤：
# 1. 复制本文件为 application-local-mysql.yml（去掉 .example）
# 2. 修改下方 url、username、password 为你的本机 MySQL 信息
# 3. 在 MySQL 中创建库： CREATE DATABASE IF NOT EXISTS nebula_ops;
# 4. 执行 nebula_ops 建表脚本后，启动应用时激活 profile：--spring.profiles.include=local-mysql
#    （IDEA 运行配置中 Active profiles 填：local-mysql）
spring:
  datasource:
    url: jdbc:mysql://localhost:3306/nebula_ops?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
    username: root
    password: 你的MySQL密码
