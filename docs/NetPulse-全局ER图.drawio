        <mxCell id="title" value="NetPulse 数据库 E-R 图（表间外键对应关系 · 用户/角色/菜单分表不合并）" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=1" vertex="1" parent="1">
