        <mxCell id="cm-sec" value="安全 security&#xa;AuthTokenInterceptor&#xa;AuthTokenService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
