  <diagram id="np-guest" name="4-员工访客">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="g-title" value="员工 / 访客（GUEST）— 访问范围与相关类" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="16" width="600" height="28" as="geometry" />
        </mxCell>
        <mxCell id="g-box1" value="角色说明&#xa;数据库/代码中角色码为 GUEST（访客），论文中可表述为「普通员工只读账号」。&#xa;不单独实现一套 Controller，与管理员、运维共用 REST API。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="1040" height="72" as="geometry" />
        </mxCell>
        <mxCell id="g-box2" value="菜单与权限&#xa;MenuConstants.ALL_MENU_CODES 定义侧栏编码；&#xa;用户登录后 UserService 按用户角色聚合 role_menu，返回可见菜单列表；&#xa;ADMIN 用户始终拥有全部菜单。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;align=left;spacingLeft=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="g-box3" value="核心关联类&#xa;UserService（getMenus 等）&#xa;RoleMenuService&#xa;RoleRepository · RoleMenuRepository&#xa;UserRoleRepository · SysUserRepository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;align=left;spacingLeft=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="150" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="g-box4" value="访客典型可访问能力（由前端路由 + 后端接口权限共同约束，具体以实际 role_menu 配置为准）&#xa;· 仪表盘、设备列表只读、指标查看、部分告警/巡检报告查看 等" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#d6b656;align=left;spacingLeft=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="1040" height="64" as="geometry" />
        </mxCell>
        <mxCell id="g-box5" value="鉴权入口（所有角色共用）&#xa;AuthController · AuthTokenService · AuthTokenInterceptor" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#6c8ebf;align=left;spacingLeft=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="1040" height="56" as="geometry" />
        </mxCell>
        <mxCell id="g-box6" value="实体：SysUser · Role · UserRole · RoleMenu（与管理员分页一致，此处强调「用户-角色-菜单」三元关系）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="1040" height="48" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
