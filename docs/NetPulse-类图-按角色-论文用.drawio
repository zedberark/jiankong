        <mxCell id="cm-app" value="入口&#xa;NetPulseApplication" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="200" height="64" as="geometry" />
