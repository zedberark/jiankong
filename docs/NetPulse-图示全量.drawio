          <mxGeometry x="370" y="40" width="100" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g0a1" value="用户访问前端（Vue）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;" vertex="1" parent="g0lane1">
