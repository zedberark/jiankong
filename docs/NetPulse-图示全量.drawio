        </mxCell>
        <mxCell id="g0d3" value="后续请求&#xa;Authorization: Bearer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=10;" vertex="1" parent="g0lane1">
          <mxGeometry x="520" y="92" width="220" height="44" as="geometry" />
