        <mxCell id="g0a6" value="前端存 netpulse_user&#xa;跳转 from 或 /dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=10;" vertex="1" parent="g0lane1">
