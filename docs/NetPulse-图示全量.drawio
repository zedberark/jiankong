        </mxCell>
        <mxCell id="g0d1" value="localStorage&#xa;有 token？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontStyle=1;fontSize=10;" vertex="1" parent="g0lane1">
          <mxGeometry x="330" y="148" width="180" height="72" as="geometry" />
        </mxCell>
        <mxCell id="g0a2" value="跳转登录页 /login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;" vertex="1" parent="g0lane1">
          <mxGeometry x="100" y="158" width="150" height="52" as="geometry" />
        </mxCell>
        <mxCell id="g0a3" value="输入用户名、密码" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;" vertex="1" parent="g0lane1">
          <mxGeometry x="100" y="230" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g0a4" value="POST /api/auth/login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontStyle=1;" vertex="1" parent="g0lane1">
          <mxGeometry x="100" y="288" width="150" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g0d2" value="密码&#xa;校验通过？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontStyle=1;fontSize=10;" vertex="1" parent="g0lane1">
          <mxGeometry x="85" y="340" width="180" height="64" as="geometry" />
        </mxCell>
        <mxCell id="g0e1" value="401 / 错误提示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=10;" vertex="1" parent="g0lane1">
          <mxGeometry x="40" y="348" width="100" height="48" as="geometry" />
        </mxCell>
        <mxCell id="g0a5" value="查询 user_role、role、role_menu&#xa;签发 token；返回 allowedMenus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=10;" vertex="1" parent="g0lane1">
          <mxGeometry x="520" y="158" width="220" height="52" as="geometry" />
