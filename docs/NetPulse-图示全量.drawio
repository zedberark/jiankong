<diagram id="er-global" name="05-数据库全局E-R关系">
    <mxGraphModel dx="1100" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="NetPulse 数据库 E-R 图（表间外键对应关系 · 用户/角色/菜单分表不合并）" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="8" width="820" height="28" as="geometry" />
        </mxCell>
        <mxCell id="hint" value="读图：矩形=数据表；连线上标注「基数 + 外键字段名」。user_role 为 用户↔角色 多对多的中间表；role_menu 仅存「某角色可访问哪些 menu_code」，与 role 是两张表。" style="text;html=1;strokeColor=#93c5fd;fillColor=#eff6ff;align=left;verticalAlign=middle;rounded=1;fontSize=10;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="24" y="38" width="920" height="36" as="geometry" />
        </mxCell>

        <mxCell id="sec1" value="一、用户 · 角色 · 菜单权限（4 张表，三处外键）" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=11;fontColor=#1d4ed8;" vertex="1" parent="1">
          <mxGeometry x="24" y="88" width="420" height="20" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="sys_user&#xa;【用户表】" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="32" y="118" width="128" height="56" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="user_role&#xa;【中间表 M:N】&#xa;PK: user_id+role_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="112" width="150" height="68" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="role&#xa;【角色表】&#xa;与菜单分表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="118" width="120" height="56" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="role_menu&#xa;【角色-菜单权限表】&#xa;FK: role_id&#xa;列: menu_code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="218" width="170" height="78" as="geometry" />
        </mxCell>

        <mxCell id="e_u_ur" value="1端 ── N端&#xa;FK: user_id → sys_user.id" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#1d4ed8;fontSize=9;fontColor=#1e40af;labelBackgroundColor=#ffffff;entryX=0;entryY=0.5;exitX=1;exitY=0.5;" edge="1" parent="1" source="t1" target="t2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ur_r" value="N端 ── 1端&#xa;FK: role_id → role.id" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#1d4ed8;fontSize=9;fontColor=#1e40af;labelBackgroundColor=#ffffff;entryX=0;entryY=0.5;exitX=1;exitY=0.5;" edge="1" parent="1" source="t2" target="t3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_r_rm" value="1端 ── N端&#xa;FK: role_id → role.id&#xa;（角色 与 菜单行 分表）" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#4f46e5;fontSize=9;fontColor=#312e81;labelBackgroundColor=#ffffff;entryX=0.5;entryY=0;exitX=0.5;exitY=1;" edge="1" parent="1" source="t3" target="t4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="sec2" value="二、设备 · 告警（外键：device_id / rule_id）" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=11;fontColor=#15803d;" vertex="1" parent="1">
          <mxGeometry x="24" y="318" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="t5" value="device&#xa;【设备表】" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="32" y="352" width="110" height="52" as="geometry" />
        </mxCell>
        <mxCell id="t6" value="alert_rule&#xa;【告警规则】&#xa;device_id 可空" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="190" y="340" width="130" height="58" as="geometry" />
        </mxCell>
        <mxCell id="t7" value="alert_history&#xa;【告警历史】" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="370" y="352" width="130" height="52" as="geometry" />
        </mxCell>
        <mxCell id="t8" value="alert_template&#xa;【告警模板】&#xa;无外键" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7c3aed;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="430" width="130" height="58" as="geometry" />
        </mxCell>

        <mxCell id="e_d_ar" value="1:N FK device_id（可空）" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#15803d;fontSize=9;labelBackgroundColor=#ffffff;entryX=0;entryY=0.5;exitX=1;exitY=0.5;" edge="1" parent="1" source="t5" target="t6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_d_ah" value="1:N FK device_id" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#15803d;fontSize=9;labelBackgroundColor=#ffffff;entryX=0;entryY=0.5;exitX=1;exitY=0.5;" edge="1" parent="1" source="t5" target="t7">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="300" y="378" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e_ar_ah" value="1:N FK rule_id" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#15803d;fontSize=9;labelBackgroundColor=#ffffff;entryX=0;entryY=0.5;exitX=1;exitY=0.5;" edge="1" parent="1" source="t6" target="t7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="sec3" value="三、系统 · 备份 · 审计 · AI" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=11;fontColor=#c2410c;" vertex="1" parent="1">
          <mxGeometry x="560" y="88" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="t9" value="system_config&#xa;键值配置" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="118" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t10" value="config_backup&#xa;FK user_id 可空" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="188" width="130" height="52" as="geometry" />
        </mxCell>
        <mxCell id="t11" value="audit_log&#xa;无 user 表 FK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="188" width="120" height="52" as="geometry" />
        </mxCell>
        <mxCell id="t12" value="ai_chat_session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#6d28d9;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="288" width="150" height="48" as="geometry" />
        </mxCell>
        <mxCell id="t13" value="ai_chat_message&#xa;FK session_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#6d28d9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="368" width="150" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e_cb_u" value="N:1 可空&#xa;FK user_id → sys_user.id" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#ea580c;dashed=1;dashPattern=5 4;fontSize=9;labelBackgroundColor=#fff7ed;entryX=1;entryY=0.5;exitX=0;exitY=0.5;" edge="1" parent="1" source="t10" target="t1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="520" y="214" /><mxPoint x="520" y="146" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e_cs_cm" value="1:N FK session_id" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#6d28d9;fontSize=9;labelBackgroundColor=#ffffff;entryX=0.5;entryY=0;exitX=0.5;exitY=1;" edge="1" parent="1" source="t12" target="t13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="note" value="对应关系小结：① 用户—角色 经 user_role 两列分别指向 sys_user 与 role；② 菜单权限在 role_menu，通过 role_id 指向 role，不是与角色混在一张表；③ alert_template 无指向他表的外键；④ audit_log 仅存 username 字符串，库中无指向 sys_user 的外键。" style="text;html=1;strokeColor=#cbd5e1;fillColor=#f8fafc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="24" y="520" width="920" height="56" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
<diagram id="p0" name="06-系统功能全流程（登录与入口）">
    <mxGraphModel dx="1100" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="920" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="g0t" value="NetPulse 系统功能全流程图（含登录、权限与主要业务入口）" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="8" width="680" height="28" as="geometry" />
        </mxCell>
        <mxCell id="g0lane1" value="一、访问与登录" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;fontSize=12;startSize=26;" vertex="1" parent="1">
