@startuml NetPulse_时序图_系统巡检
!theme plain
skinparam sequenceMessageAlign center

title NetPulse — 时序图：手动触发系统巡检（POST /api/inspection/run）

actor "运维用户" as U
participant "浏览器" as FE
participant "InspectionController\n/api/inspection" as IC
participant "InspectionService" as IS
participant "MonitorService\n(可达性探测)" as MON
participant "DeviceRepository" as DR
database "MySQL" as DB
participant "大模型 API\n(可选 AI 结论)" as LLM

U -> FE: 选择分组、勾选 AI 结论、提交
FE -> IC: POST /api/inspection/run\n{ group, ai: true/false }

IC -> IS: runInspection(group)

IS -> DR: 查询待巡检设备
DR -> DB: SELECT ...
DB --> DR: 设备列表
DR --> IS: devices

loop 每台设备
  IS -> MON: Ping/TCP 探测
  MON --> IS: RTT、在线/离线状态
end

IS -> DB: 写入 inspection_report、inspection_item
DB --> IS: 报告 ID

IC -> IC: auditService.log(RUN_INSPECTION, ...)

alt 请求体 ai = true
  IC -> IS: generateAiSummary(reportId, user)
  IS -> LLM: 结构化巡检数据 → 生成 Markdown 结论
  LLM --> IS: ai_summary 文本
  IS -> DB: UPDATE report.ai_summary
  IC -> IC: auditService.log(AI_INSPECTION, ...)
end

IC --> FE: 200 InspectionReport(JSON)

@enduml
